{
	"name": "nanocoder-vscode",
	"displayName": "Nanocoder",
	"description": "VS Code integration for Nanocoder - local-first AI coding assistant",
	"version": "0.3.0",
	"publisher": "nanocollective",
	"repository": {
		"type": "git",
		"url": "https://github.com/Nano-Collective/nanocoder.git"
	},
	"engines": {
		"vscode": "^1.125.0"
	},
	"categories": [
		"Programming Languages",
		"Machine Learning",
		"Other"
	],
	"keywords": [
		"ai",
		"coding",
		"assistant",
		"nanocoder",
		"ollama",
		"local"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"icon": "media/icon.png",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "nanocoder-sidebar",
					"title": "Nanocoder",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"nanocoder-sidebar": [
				{
					"type": "webview",
					"id": "nanocoder.chatView",
					"name": "Chat",
					"icon": "media/icon.svg"
				}
			]
		},
		"commands": [
			{
				"command": "nanocoder.connect",
				"title": "Connect to Nanocoder",
				"category": "Nanocoder"
			},
			{
				"command": "nanocoder.disconnect",
				"title": "Disconnect from Nanocoder",
				"category": "Nanocoder"
			},
			{
				"command": "nanocoder.startCli",
				"title": "Start Nanocoder CLI",
				"category": "Nanocoder"
			}
		],
		"configuration": {
			"title": "Nanocoder",
			"properties": {
				"nanocoder.serverPort": {
					"type": "number",
					"default": 51820,
					"description": "WebSocket server port for communication with Nanocoder CLI"
				},
				"nanocoder.autoConnect": {
					"type": "boolean",
					"default": true,
					"description": "Automatically connect to Nanocoder CLI on startup"
				},
				"nanocoder.autoStartCli": {
					"type": "boolean",
					"default": false,
					"description": "Automatically start Nanocoder CLI if not running"
				},
				"nanocoder.showDiffPreview": {
					"type": "boolean",
					"default": true,
					"description": "Show diff preview before applying file changes"
				},
				"nanocoder.mode": {
					"type": "string",
					"default": "auto-accept",
					"scope": "resource",
					"description": "The current operating mode for the Nanocoder assistant (e.g. chat, auto-accept)"
				},
				"nanocoder.model": {
					"type": "string",
					"default": "google/gemini-3.5-flash",
					"scope": "machine",
					"description": "The AI model to use for Nanocoder sessions"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run build",
		"build": "concurrently \"pnpm run build:ext\" \"pnpm run build:css\"",
		"watch": "concurrently \"pnpm run watch:ext\" \"pnpm run watch:css\"",
		"build:ext": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
		"watch:ext": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
		"build:css": "tailwindcss -i ./src/styles.css -o ./media/chat-panel.css --minify",
		"watch:css": "tailwindcss -i ./src/styles.css -o ./media/chat-panel.css --watch",
		"lint": "eslint src --ext ts"
	},
	"devDependencies": {
		"@types/node": "^25.9.3",
		"@types/vscode": "^1.125.0",
		"@types/ws": "^8.5.10",
		"@vscode/vsce": "^3.9.1",
		"autoprefixer": "^10.4.19",
		"concurrently": "^8.2.2",
		"esbuild": "^0.28.1",
		"eslint": "^10.1.0",
		"postcss": "^8.4.38",
		"tailwindcss": "^3.4.4",
		"typescript": "^5.3.0"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.25.0",
		"ws": "^8.16.0"
	}
}
