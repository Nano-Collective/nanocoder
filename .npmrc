# nanocoder is developed and released with pnpm, which tolerates optional-peer
# version mismatches. Downstream consumers install it with plain `npm install`
# (e.g. Nano Collective's contentforest CI clones this repo and runs npm), where
# npm's strict resolver turns an *optional* peer mismatch into a fatal ERESOLVE:
# @nanocollective/get-md declares peerOptional @ai-sdk/google@^3, but we ship v4.
# legacy-peer-deps restores npm's pre-v7 behaviour so those installs succeed.
# pnpm ignores this key, so our own tooling is unaffected.
legacy-peer-deps=true
